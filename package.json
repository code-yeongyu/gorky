{
  "name": "gorky",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "build": "pnpm --filter @gorky/web build",
    "models:sync": "node --experimental-strip-types scripts/sync-grok-models.ts",
    "qa:grok-models": "node --experimental-strip-types scripts/qa-grok-models.ts",
    "qa:live": "node --experimental-strip-types scripts/qa-live.ts",
    "preview:web": "pnpm --filter @gorky/web preview"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.5",
    "hono": "^4.12.23",
    "ky": "^2.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.96.0"
  }
}
